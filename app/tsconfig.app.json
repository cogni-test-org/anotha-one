{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/shared/*": ["src/shared/*"],
      "@/core": ["src/core/public.ts"],
      "@/ports": ["src/ports/index.ts"],
      "@/adapters/server": ["src/adapters/server/index.ts"],
      "@/shared": ["src/shared/index.ts"],
      "@features/*": ["src/features/*"],
      "@app/*": ["src/app/*"],
      "@adapters/*": ["src/adapters/*"],
      "@bootstrap/*": ["src/bootstrap/*"],
      "@components/*": ["src/components/*"],
      "@styles/*": ["src/styles/*"],
      "@types/*": ["src/types/*"],
      "@assets/*": ["src/assets/*"],
      "@tests/*": ["tests/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "**/dist/**",
    ".next/**",
    "node_modules/**",
    "coverage/**",
    "**/__arch_probes__/**",
    "src/components/reui/**"
  ]
}
