{
  "name": "@cogni/attribution-ledger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./epoch-window": {
      "types": "./dist/epoch-window.d.ts",
      "import": "./dist/epoch-window.js",
      "default": "./dist/epoch-window.js"
    },
    "./allocation": {
      "types": "./dist/allocation.d.ts",
      "import": "./dist/allocation.js",
      "default": "./dist/allocation.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/index.js')){console.error('ERROR: dist/index.js missing'); process.exit(1)}\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
